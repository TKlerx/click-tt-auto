{
  "name": "click-tt-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI automation for approving click-TT match reports.",
  "scripts": {
    "approve": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "validate": "powershell -ExecutionPolicy Bypass -File ./validate.ps1"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "minimist": "^1.2.8",
    "playwright": "^1.56.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/jsdom": "^27.0.0",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.7.2",
    "eslint": "^9.37.0",
    "globals": "^16.4.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  }
}

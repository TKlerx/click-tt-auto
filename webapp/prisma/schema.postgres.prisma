generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PLATFORM_ADMIN
  SCOPE_ADMIN
  SCOPE_USER
}

enum UserStatus {
  PENDING_APPROVAL
  ACTIVE
  INACTIVE
}

enum AuthMethod {
  SSO
  LOCAL
  BOTH
}

enum ThemePreference {
  LIGHT
  DARK
}

enum TokenType {
  PAT
  CLI_LOGIN
}

enum TokenStatus {
  ACTIVE
  REVOKED
}

enum AuditAction {
  USER_CREATED
  ROLE_CHANGED
  SCOPE_ASSIGNMENT_CHANGED
  USER_STATUS_CHANGED
  USER_THEME_CHANGED
  AUTH_LOGIN_SUCCEEDED
  AUTH_LOGIN_REJECTED
  AUTH_PASSWORD_CHANGED
  AUTH_LOGOUT_SUCCEEDED
  AUDIT_EXPORT_REQUESTED
  PAT_CREATED
  PAT_REVOKED
  PAT_RENEWED
  PAT_DELETED
  CLI_LOGIN_COMPLETED
  RASTER_INPUT_UPLOADED
  RASTER_PLANNING_CHANGED
  RASTER_RUN_STARTED
  RASTER_CAPACITY_CHANGED
  RASTER_REVIEW_DECISION_CHANGED
}

enum BackgroundJobStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum NotificationEventType {
  USER_CREATED
  ROLE_CHANGED
  USER_STATUS_CHANGED
  SCOPE_ASSIGNMENT_CHANGED
}

enum NotificationStatus {
  QUEUED
  SENDING
  RETRYING
  SENT
  FAILED
  BOUNCED
}

enum InboundEmailStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum TeamsMessageStatus {
  QUEUED
  SENDING
  RETRYING
  SENT
  FAILED
}

enum TeamsInboundStatus {
  RECEIVED
  PROCESSED
  IGNORED
}

enum RasterWeekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum InputSetStatus {
  DRAFT
  READY
}

enum RasterWishSource {
  PDF_PARSED
  LLM_PASTED
  STRUCTURED
}

enum RasterConfidence {
  OK
  REVIEW
}

enum RasterWishOrigin {
  IMPORTED
  MANUAL
}

enum RasterWishImportKind {
  PDF
  JSON
}

enum RasterConflictDecision {
  KEEP_EXISTING
  USE_IMPORTED
  MANUAL
}

enum HallCapacityBasis {
  REVIEWED
  INFERRED
  MISSING
}

enum FixedRasterzahlSource {
  PDF
  MANUAL
  STRUCTURED
}

enum OptimizationRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum OptimizationRunOutcome {
  PROVEN_OPTIMAL
  FEASIBLE
  INFEASIBLE
  FAILED
  CANCELLED
}

enum SnapshotOrigin {
  GENERATED
  IMPORTED
}

enum SnapshotOptimality {
  PROVEN_OPTIMAL
  FEASIBLE
  IMPORTED_HEURISTIC
}

enum AssignmentStatus {
  OPTIMIZED
  FIXED
  PINNED
  MISSING
}

enum ReviewTargetType {
  CONFLICT
  CLUB_SUMMARY
}

enum ReviewDecisionStatus {
  REVIEWED
  NEEDS_CORRECTION
  ACCEPTED_UNAVOIDABLE
}

enum RasterMatchRecordType {
  TEAM
}

enum RosterCharset {
  UTF8
  ISO_8859_15
}

model User {
  id                            String                        @id @default(cuid())
  email                         String                        @unique
  emailVerified                 Boolean                       @default(false)
  name                          String
  image                         String?
  role                          Role                          @default(SCOPE_USER)
  status                        UserStatus                    @default(PENDING_APPROVAL)
  authMethod                    AuthMethod
  mustChangePassword            Boolean                       @default(true)
  themePreference               ThemePreference               @default(LIGHT)
  locale                        String                        @default("en")
  createdAt                     DateTime                      @default(now())
  updatedAt                     DateTime                      @updatedAt
  accounts                      Account[]
  sessions                      Session[]
  scopeAssignments              UserScopeAssignment[]
  auditEntries                  AuditEntry[]                  @relation("AuditActor")
  backgroundJobs                BackgroundJob[]               @relation("BackgroundJobCreator")
  rasterWishImportBatches       RasterWishImportBatch[]       @relation("RasterWishImportStarter")
  reviewedRasterWishes          RasterWish[]                  @relation("RasterWishReviewer")
  decidedRasterWishConflicts    RasterWishConflict[]          @relation("RasterWishConflictDecider")
  personalAccessTokens          PersonalAccessToken[]
  cliAuthCodes                  CliAuthCode[]
  teamsIntegrationConfigUpdates TeamsIntegrationConfig[]      @relation("TeamsIntegrationUpdatedBy")
  teamsDeliveryTargets          TeamsDeliveryTarget[]         @relation("TeamsDeliveryTargetCreator")
  teamsIntakeSubscriptions      TeamsIntakeSubscription[]     @relation("TeamsIntakeSubscriptionCreator")
  teamsDelegatedGrant           TeamsDelegatedGrant?
  rasterInputSets               RasterInputSet[]              @relation("RasterInputSetCreator")
  rasterRuns                    RasterOptimizationRun[]       @relation("RasterRunStarter")
  rasterCapacityUpdates         RasterHallCapacity[]          @relation("RasterCapacityUpdater")
  rasterReviewDecisions         RasterReviewDecision[]        @relation("RasterReviewDecider")
  rasterMatchReviews            RasterMatchReview[]           @relation("RasterMatchReviewer")
  rasterManualAssignmentDrafts  RasterManualAssignmentDraft[] @relation("RasterManualAssignmentDraftCreator")
  rasterTeamRosters             RasterTeamRoster[]            @relation("RasterTeamRosterImporter")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Scope {
  id                   String                @id @default(cuid())
  name                 String                @unique
  code                 String                @unique
  parentId             String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  parent               Scope?                @relation("ScopeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children             Scope[]               @relation("ScopeHierarchy")
  userAssignments      UserScopeAssignment[]
  auditEntries         AuditEntry[]
  rasterSources        RasterSource[]
  rasterInputSets      RasterInputSet[]
  rasterInputSetScopes RasterInputSetScope[]
  rasterHallCapacities RasterHallCapacity[]
  rasterSnapshots      RasterSnapshot[]
  rasterTeamRosters    RasterTeamRoster[]
  rasterSnapshotScopes RasterSnapshotScope[]

  @@index([parentId])
}

model RasterSource {
  id          String          @id @default(cuid())
  scopeId     String
  inputSetId  String?
  season      String          @default("2026/27")
  sourceType  String
  sourceRef   String
  displayName String
  contentHash String?
  parsedJson  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  scope       Scope           @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  inputSet    RasterInputSet? @relation(fields: [inputSetId], references: [id], onDelete: SetNull)

  @@unique([inputSetId, sourceType, sourceRef])
  @@index([scopeId, season, sourceType])
  @@index([inputSetId])
}

model UserScopeAssignment {
  id        String   @id @default(cuid())
  userId    String
  scopeId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope     Scope    @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@unique([userId, scopeId])
  @@index([scopeId])
}

model AuditEntry {
  id         String      @id @default(cuid())
  action     AuditAction
  entityType String
  entityId   String
  actorId    String
  scopeId    String?
  details    String
  createdAt  DateTime    @default(now())
  actor      User        @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  scope      Scope?      @relation(fields: [scopeId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([scopeId])
  @@index([createdAt])
}

model PersonalAccessToken {
  id           String      @id @default(cuid())
  name         String
  tokenHash    String      @unique
  tokenPrefix  String
  userId       String
  type         TokenType
  expiresAt    DateTime
  lastUsedAt   DateTime?
  status       TokenStatus @default(ACTIVE)
  revokedAt    DateTime?
  renewalCount Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([tokenHash])
  @@index([userId, status])
  @@index([status, expiresAt])
}

model CliAuthCode {
  id          String   @id @default(cuid())
  code        String   @unique
  state       String
  callbackUrl String
  userId      String?
  exchanged   Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([expiresAt])
}

model BackgroundJob {
  id              String              @id @default(cuid())
  jobType         String
  status          BackgroundJobStatus @default(PENDING)
  payload         String
  result          String?
  error           String?
  attemptCount    Int                 @default(0)
  availableAt     DateTime            @default(now())
  startedAt       DateTime?
  lockedAt        DateTime?
  finishedAt      DateTime?
  workerId        String?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  createdBy       User?               @relation("BackgroundJobCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([status, availableAt])
  @@index([createdByUserId, createdAt])
  @@index([jobType, createdAt])
}

model NotificationEvent {
  id                    String                 @id @default(cuid())
  eventType             NotificationEventType
  actorId               String?
  affectedUserId        String?
  payload               String                 @default("{}")
  createdAt             DateTime               @default(now())
  notifications         Notification[]
  teamsOutboundMessages TeamsOutboundMessage[]

  @@index([eventType, createdAt])
  @@index([actorId, createdAt])
  @@index([affectedUserId, createdAt])
}

model NotificationTypeConfiguration {
  eventType       NotificationEventType @id
  enabled         Boolean               @default(true)
  updatedByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

model Notification {
  id                String             @id @default(cuid())
  eventId           String
  recipientEmail    String
  recipientUserId   String?
  locale            String             @default("en")
  subject           String
  bodyText          String
  bodyHtml          String?
  status            NotificationStatus @default(QUEUED)
  retryCount        Int                @default(0)
  providerMessageId String?
  lastError         String?
  sentAt            DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  event             NotificationEvent  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([status, createdAt])
  @@index([recipientEmail, status])
  @@index([recipientUserId, createdAt])
}

model InboundEmail {
  id                       String             @id @default(cuid())
  providerMessageId        String             @unique
  mailbox                  String
  internetMessageId        String?
  conversationId           String?
  senderEmail              String?
  senderName               String?
  subject                  String
  bodyPreview              String?
  bodyText                 String?
  bodyHtml                 String?
  inReplyTo                String?
  referenceIds             String             @default("[]")
  receivedAt               DateTime
  processingStatus         InboundEmailStatus @default(RECEIVED)
  processingNotes          String?
  correlatedNotificationId String?
  linkedEntityType         String?
  linkedEntityId           String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([processingStatus, receivedAt])
  @@index([mailbox, receivedAt])
  @@index([correlatedNotificationId, receivedAt])
  @@index([linkedEntityType, linkedEntityId])
}

model TeamsIntegrationConfig {
  id              String   @id @default(cuid())
  sendEnabled     Boolean  @default(false)
  intakeEnabled   Boolean  @default(false)
  updatedByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  updatedBy       User?    @relation("TeamsIntegrationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
}

model TeamsDeliveryTarget {
  id               String                 @id @default(cuid())
  name             String
  teamId           String
  channelId        String
  teamName         String?
  channelName      String?
  active           Boolean                @default(true)
  createdByUserId  String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  createdBy        User                   @relation("TeamsDeliveryTargetCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  outboundMessages TeamsOutboundMessage[]

  @@unique([teamId, channelId])
  @@index([active])
}

model TeamsOutboundMessage {
  id             String                @id @default(cuid())
  targetId       String
  eventType      NotificationEventType
  eventId        String?
  content        String
  contentType    String                @default("html")
  truncated      Boolean               @default(false)
  status         TeamsMessageStatus    @default(QUEUED)
  graphMessageId String?
  attemptCount   Int                   @default(0)
  lastError      String?
  sentAt         DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  target         TeamsDeliveryTarget   @relation(fields: [targetId], references: [id], onDelete: Restrict)
  event          NotificationEvent?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([targetId, createdAt])
  @@index([status, createdAt])
  @@index([eventType, createdAt])
}

model TeamsIntakeSubscription {
  id              String                @id @default(cuid())
  teamId          String
  channelId       String
  teamName        String?
  channelName     String?
  active          Boolean               @default(true)
  deltaToken      String?
  lastPolledAt    DateTime?
  createdByUserId String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdBy       User                  @relation("TeamsIntakeSubscriptionCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  inboundMessages TeamsInboundMessage[]

  @@unique([teamId, channelId])
  @@index([active])
}

model TeamsInboundMessage {
  id                String                  @id @default(cuid())
  subscriptionId    String
  providerMessageId String                  @unique
  teamId            String
  channelId         String
  senderDisplayName String?
  senderUserId      String?
  content           String?
  contentType       String?
  truncated         Boolean                 @default(false)
  processingStatus  TeamsInboundStatus      @default(RECEIVED)
  processingNotes   String?
  messageCreatedAt  DateTime
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  subscription      TeamsIntakeSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([subscriptionId, createdAt])
  @@index([processingStatus, createdAt])
  @@index([channelId, messageCreatedAt])
}

model TeamsDelegatedGrant {
  id           String    @id @default(cuid())
  userId       String    @unique
  scope        String
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
}

model RasterInputSet {
  id                     String                        @id @default(cuid())
  name                   String
  scopeId                String
  season                 String                        @default("2026/27")
  createdById            String
  createdAt              DateTime                      @default(now())
  status                 InputSetStatus                @default(DRAFT)
  seasonModelJson        String?
  groupAssignmentJson    String?
  wishesJson             String?
  scope                  Scope                         @relation(fields: [scopeId], references: [id], onDelete: Restrict)
  createdBy              User                          @relation("RasterInputSetCreator", fields: [createdById], references: [id], onDelete: Restrict)
  wishes                 RasterWish[]
  wishImportBatches      RasterWishImportBatch[]
  wishImportRows         RasterImportedWishRow[]
  wishConflicts          RasterWishConflict[]
  fixedRasterzahlen      RasterFixedRasterzahl[]
  runs                   RasterOptimizationRun[]
  spannedScopes          RasterInputSetScope[]
  matchReviews           RasterMatchReview[]
  manualAssignmentDrafts RasterManualAssignmentDraft[]
  rasterSources          RasterSource[]

  @@index([scopeId, season, createdAt])
  @@index([createdById])
}

model RasterInputSetScope {
  id         String         @id @default(cuid())
  inputSetId String
  scopeId    String
  inputSet   RasterInputSet @relation(fields: [inputSetId], references: [id], onDelete: Cascade)
  scope      Scope          @relation(fields: [scopeId], references: [id], onDelete: Restrict)

  @@unique([inputSetId, scopeId])
  @@index([scopeId])
}

model RasterWish {
  id                  String                  @id @default(cuid())
  inputSetId          String
  clubId              String
  clubName            String
  teamLabel           String?
  homeWeekday         RasterWeekday
  hall                String?
  startTime           String?
  spielwochePref      String?
  requestedRasterzahl String?
  notes               String?
  source              RasterWishSource
  confidence          RasterConfidence        @default(REVIEW)
  origin              RasterWishOrigin        @default(IMPORTED)
  reviewedAt          DateTime?
  reviewedById        String?
  inputSet            RasterInputSet          @relation(fields: [inputSetId], references: [id], onDelete: Cascade)
  reviewedBy          User?                   @relation("RasterWishReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  importedRows        RasterImportedWishRow[]
  conflicts           RasterWishConflict[]

  @@unique([inputSetId, clubId, teamLabel])
  @@index([inputSetId])
  @@index([clubId])
  @@index([reviewedById])
}

model RasterWishImportBatch {
  id          String                  @id @default(cuid())
  inputSetId  String
  startedById String
  startedAt   DateTime                @default(now())
  sourceKind  RasterWishImportKind
  inputSet    RasterInputSet          @relation(fields: [inputSetId], references: [id], onDelete: Cascade)
  startedBy   User                    @relation("RasterWishImportStarter", fields: [startedById], references: [id], onDelete: Restrict)
  rows        RasterImportedWishRow[]

  @@index([inputSetId, startedAt])
  @@index([startedById])
}

model RasterImportedWishRow {
  id                  String                @id @default(cuid())
  batchId             String
  inputSetId          String
  sourceFile          String?
  matchedWishId       String?
  clubId              String
  clubName            String
  teamLabel           String?
  homeWeekday         RasterWeekday
  hall                String?
  startTime           String?
  spielwochePref      String?
  requestedRasterzahl String?
  notes               String?
  valueFingerprint    String
  // This row is the one that brought the wish into existence, which is what
  // "added by this import" means (FR-011).
  createdWish         Boolean               @default(false)
  batch               RasterWishImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  inputSet            RasterInputSet        @relation(fields: [inputSetId], references: [id], onDelete: Cascade)
  matchedWish         RasterWish?           @relation(fields: [matchedWishId], references: [id], onDelete: SetNull)
  conflicts           RasterWishConflict[]

  @@index([batchId])
  @@index([inputSetId])
  @@index([matchedWishId])
}

model RasterWishConflict {
  id                String                  @id @default(cuid())
  inputSetId        String
  wishId            String
  importedRowId     String
  differingFields   String
  decision          RasterConflictDecision?
  // The wish as it stood when the decision was taken, so the audit trail keeps
  // the value the decision replaced (FR-010), not just the one it chose.
  previousValueJson String?
  decidedValueJson  String?
  decidedById       String?
  decidedAt         DateTime?
  inputSet          RasterInputSet          @relation(fields: [inputSetId], references: [id], onDelete: Cascade)
  wish              RasterWish              @relation(fields: [wishId], references: [id], onDelete: Cascade)
  importedRow       RasterImportedWishRow   @relation(fields: [importedRowId], references: [id], onDelete: Cascade)
  decidedBy         User?                   @relation("RasterWishConflictDecider", fields: [decidedById], references: [id], onDelete: SetNull)

  @@unique([wishId, importedRowId])
  @@index([inputSetId, decision])
  @@index([decidedById])
}

model RasterHallCapacity {
  id          String            @id @default(cuid())
  scopeId     String
  clubId      String
  hall        String
  weekday     RasterWeekday
  capacity    Int
  basis       HallCapacityBasis @default(MISSING)
  updatedById String?
  updatedAt   DateTime          @updatedAt
  scope       Scope             @relation(fields: [scopeId], references: [id], onDelete: Restrict)
  updatedBy   User?             @relation("RasterCapacityUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([scopeId, clubId, hall, weekday])
  @@index([scopeId, clubId])
  @@index([updatedById])
}

model RasterFixedRasterzahl {
  id         String                @id @default(cuid())
  inputSetId String
  clubId     String
  teamLabel  String
  rasterzahl Int
  source     FixedRasterzahlSource
  inputSet   RasterInputSet        @relation(fields: [inputSetId], references: [id], onDelete: Cascade)

  @@index([inputSetId])
  @@index([clubId])
}

model RasterOptimizationRun {
  id                 String                  @id @default(cuid())
  inputSetId         String
  startedById        String
  jobId              String?
  status             OptimizationRunStatus   @default(PENDING)
  outcome            OptimizationRunOutcome?
  objectiveValue     Float?
  objectiveBreakdown String?
  solverStatus       String?
  settings           String                  @default("{}")
  coverageComplete   Boolean                 @default(false)
  coverageJson       String                  @default("{}")
  createdAt          DateTime                @default(now())
  finishedAt         DateTime?
  archivedAt         DateTime?
  inputSet           RasterInputSet          @relation(fields: [inputSetId], references: [id], onDelete: Restrict)
  startedBy          User                    @relation("RasterRunStarter", fields: [startedById], references: [id], onDelete: Restrict)
  snapshot           RasterSnapshot?

  @@index([inputSetId, createdAt])
  @@index([startedById])
  @@index([status, createdAt])
  @@index([archivedAt])
  @@index([coverageComplete])
}

model RasterSnapshot {
  id                 String                 @id @default(cuid())
  runId              String?                @unique
  scopeId            String
  origin             SnapshotOrigin
  optimality         SnapshotOptimality
  stale              Boolean                @default(false)
  totalConflicts     Int                    @default(0)
  totalExcess        Int                    @default(0)
  maxExcess          Int                    @default(0)
  affectedClubs      Int                    @default(0)
  objectiveBreakdown String                 @default("{}")
  createdAt          DateTime               @default(now())
  archivedAt         DateTime?
  scope              Scope                  @relation(fields: [scopeId], references: [id], onDelete: Restrict)
  run                RasterOptimizationRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  assignments        RasterAssignment[]
  conflicts          RasterConflict[]
  reviewDecisions    RasterReviewDecision[]
  spannedScopes      RasterSnapshotScope[]

  @@index([scopeId, createdAt])
  @@index([stale])
  @@index([archivedAt])
}

model RasterSnapshotScope {
  id         String         @id @default(cuid())
  snapshotId String
  scopeId    String
  snapshot   RasterSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  scope      Scope          @relation(fields: [scopeId], references: [id], onDelete: Restrict)

  @@unique([snapshotId, scopeId])
}

model RasterMatchReview {
  id           String                @id @default(cuid())
  inputSetId   String
  recordType   RasterMatchRecordType
  recordId     String
  fingerprint  String
  reviewedById String
  reviewedAt   DateTime              @default(now())
  inputSet     RasterInputSet        @relation(fields: [inputSetId], references: [id], onDelete: Cascade)
  reviewedBy   User                  @relation("RasterMatchReviewer", fields: [reviewedById], references: [id], onDelete: Restrict)

  @@unique([inputSetId, recordType, recordId])
  @@index([inputSetId])
  @@index([reviewedById])
}

model RasterAssignment {
  id         String           @id @default(cuid())
  snapshotId String
  league     String
  group      String
  clubId     String
  clubName   String
  team       String
  rasterzahl Int
  status     AssignmentStatus
  weekday    RasterWeekday
  hall       String
  startTime  String?
  weekSlot   String?
  snapshot   RasterSnapshot   @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, clubId])
  @@index([snapshotId, league, group])
}

model RasterConflict {
  id          String         @id @default(cuid())
  snapshotId  String
  matchWeek   Int
  clubId      String
  clubName    String
  weekday     RasterWeekday
  hall        String
  capacity    Int
  actualCount Int
  excess      Int
  teams       String
  snapshot    RasterSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId, clubId])
  @@index([snapshotId, excess])
}

model RasterReviewDecision {
  id          String               @id @default(cuid())
  snapshotId  String
  targetType  ReviewTargetType
  targetId    String
  status      ReviewDecisionStatus
  note        String?
  decidedById String
  decidedAt   DateTime             @default(now())
  snapshot    RasterSnapshot       @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  decidedBy   User                 @relation("RasterReviewDecider", fields: [decidedById], references: [id], onDelete: Restrict)

  @@index([snapshotId, targetType, targetId])
  @@index([decidedById])
}

model RasterManualAssignmentDraft {
  id                   String         @id @default(cuid())
  inputSetId           String
  name                 String
  rowsJson             String
  validationIssuesJson String         @default("[]")
  createdById          String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  inputSet             RasterInputSet @relation(fields: [inputSetId], references: [id], onDelete: Cascade)
  createdBy            User           @relation("RasterManualAssignmentDraftCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@index([inputSetId, updatedAt])
  @@index([createdById])
}

model RasterTeamRoster {
  id           String             @id @default(cuid())
  scopeId      String
  season       String
  sourceRegion String
  sourceSeason String
  charset      RosterCharset
  importedById String
  importedAt   DateTime           @default(now())
  scope        Scope              @relation(fields: [scopeId], references: [id], onDelete: Restrict)
  importedBy   User               @relation("RasterTeamRosterImporter", fields: [importedById], references: [id], onDelete: Restrict)
  teams        RasterRosterTeam[]

  @@index([scopeId, season, importedAt])
}

model RasterRosterTeam {
  id           String           @id @default(cuid())
  rosterId     String
  vereinNr     String
  vereinName   String
  altersklasse String
  mannschaftNr String
  liga         String
  gruppe       String
  roster       RasterTeamRoster @relation(fields: [rosterId], references: [id], onDelete: Cascade)

  @@unique([rosterId, vereinNr, altersklasse, mannschaftNr])
  @@index([rosterId, vereinNr])
  @@index([rosterId, gruppe])
}
